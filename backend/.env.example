# Django Settings
DEBUG=True
SECRET_KEY=django-insecure-change-this-in-production
DATABASE_NAME=zLyrics
DATABASE_USER=root
DATABASE_PASS=your_mysql_password
DB_HOST=localhost

# Spotify API (Required)
# Get from: https://developer.spotify.com/dashboard/
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Genius API (Fallback lyrics source)
# Get from: https://genius.com/api-clients
GENIUS_ACCESS_TOKEN=your_genius_access_token

# Musixmatch API (Primary lyrics source - better coverage than Genius)
# Get from: https://developer.musixmatch.com/
MUSIXMATCH_API_KEY=your_musixmatch_api_key

# Anthropic API (Required for AI Agent)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key

# Google OAuth (Optional)
# Get from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id

# Deepgram API (Optional - improves sync quality)
# Get from: https://console.deepgram.com/
DEEPGRAM_API_KEY=your_deepgram_api_key

# Groq API (Recommended - provides fast Whisper transcription for perfect sync)
# Get from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key

# Celery Settings
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
